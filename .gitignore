# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# --- Rails defaults --------------------------------------------------------

# Bundler config + locally-vendored gems.
/.bundle
/vendor/bundle

# Ignore the default SQLite database (if used).
/db/*.sqlite3
/db/*.sqlite3-journal
/db/*.sqlite3-*

# Logs and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Storage (uploaded files in development; SQLite-disk storage).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Public assets compiled by Propshaft.
/public/assets

# Debugger / Ruby tooling state.
/.byebug_history

# Master and per-environment encryption keys. The broad rule covers
# config/master.key, config/credentials/*.key, and any future
# *.key file added under config/.
/config/*.key
/config/credentials/*.key

# --- JS / CSS bundling -----------------------------------------------------

# node_modules and bundler error logs.
/node_modules
yarn-error.log

# bun/jsbundling output.
/app/assets/builds/*
!/app/assets/builds/.keep

# --- RSpec + coverage ------------------------------------------------------

/coverage
/spec/examples.txt
/.rspec_status

# --- Editors / OS ----------------------------------------------------------

.idea/
.vscode/
*.iml
*.swp
*.swo
.DS_Store

# --- Local env / secrets ---------------------------------------------------

.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Claude Code per-machine local settings.
.claude/settings.local.json

# Superpowers visual companion / brainstorm session artifacts.
.superpowers/

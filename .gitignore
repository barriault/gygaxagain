# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# macOS
.DS_Store

# Logs
*.log

# Env
.env
.env.local

# Copyrighted reference material (PDFs, etc.) — local-only
# Note: references/ directory is not ignored wholesale so that committed test
# fixtures (e.g., test-bestiary.md) can be tracked. Individual copyrighted
# files are ignored by extension instead.
references/*.pdf
references/*.txt

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/

<%= helpers.turbo_stream_from [scene, scene.campaign.user] %>

<div class="min-h-screen bg-slate-900 text-slate-100 flex flex-col">
  <header class="play-header px-4 py-4 border-b border-slate-800 flex items-center gap-4">
    <div class="flex-1">
      <p class="text-xs uppercase tracking-widest text-slate-500"><%= campaign.name %></p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight"><%= scene.title %></h1>
    </div>
    <button disabled title="Scene transitions arrive in Phase 9.3"
            class="rounded border border-slate-700 px-3 py-1 text-sm text-slate-500 cursor-not-allowed opacity-50">
      Scenes ▾
    </button>
  </header>

  <div class="play-grid flex flex-1 overflow-hidden">
    <main class="play-stream flex-1 overflow-y-auto px-4 py-6">
      <% if scene.summary.present? %>
        <p class="mb-6 text-slate-400"><%= scene.summary %></p>
      <% end %>
      <%= render Play::Scenes::LogComponent.new(scene: scene) %>
    </main>

    <%= render Play::Roster::SidebarComponent.new(scene: scene) %>
  </div>

  <%= render Play::StateIndicatorComponent.new(scene: scene) %>
  <%= render Play::ComposerComponent.new(scene: scene) %>
</div>

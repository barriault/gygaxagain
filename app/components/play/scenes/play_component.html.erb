<%= helpers.turbo_stream_from [scene, scene.campaign.user] %>

<div class="h-screen bg-slate-900 text-slate-100 flex flex-col overflow-hidden">
  <header class="play-header flex-none px-6 py-4 border-b border-slate-800 flex items-center gap-4 bg-slate-900">
    <div class="flex-1 min-w-0">
      <p class="text-xs uppercase tracking-widest text-slate-500 truncate"><%= campaign.name %></p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight truncate"><%= scene.title %></h1>
    </div>
    <button disabled title="Scene transitions arrive in Phase 9.3"
            class="rounded border border-slate-700 px-3 py-1 text-sm text-slate-500 cursor-not-allowed opacity-50">
      Scenes ▾
    </button>
  </header>

  <div class="play-grid flex flex-1 min-h-0 overflow-hidden">
    <main class="play-stream flex-1 min-w-0 overflow-y-auto px-6 py-6 space-y-4">
      <% if scene.summary.present? %>
        <p class="mb-6 text-slate-400 italic"><%= scene.summary %></p>
      <% end %>
      <%= render Play::Scenes::LogComponent.new(scene: scene) %>
    </main>

    <%= render Play::Roster::SidebarComponent.new(scene: scene) %>
  </div>

  <%= render Play::StateIndicatorComponent.new(scene: scene) %>
  <%= render Play::ComposerComponent.new(scene: scene) %>
</div>

<%= helpers.turbo_stream_from [scene, scene.campaign.user] %>

<div class="min-h-screen bg-slate-900 text-slate-100 flex flex-col">
  <header class="play-header sticky top-12 z-20 px-6 py-4 border-b border-slate-800 flex items-center gap-4 bg-slate-900/95 backdrop-blur">
    <div class="flex-1 min-w-0">
      <p class="text-xs uppercase tracking-widest text-slate-500 truncate"><%= campaign.name %></p>
      <h1 class="mt-1 text-2xl font-bold tracking-tight truncate"><%= scene.title %></h1>
    </div>
    <button disabled title="Scene transitions arrive in Phase 9.3"
            class="rounded border border-slate-700 px-3 py-1 text-sm text-slate-500 cursor-not-allowed opacity-50">
      Scenes ▾
    </button>
    <%= button_to "Reset scene",
                  helpers.play_campaign_scene_reset_path(scene.campaign, scene),
                  method: :post,
                  data: { turbo_confirm: "Clear all events and LLM history for this scene? This cannot be undone." },
                  class: "rounded border border-rose-800 px-3 py-1 text-sm text-rose-300 hover:bg-rose-900/40 hover:border-rose-600" %>
  </header>

  <div class="play-grid flex flex-1 relative">
    <main class="play-stream flex-1 min-w-0 px-6 py-6 pb-40 space-y-4">
      <% if scene.summary.present? %>
        <p class="mb-6 text-slate-400 italic"><%= scene.summary %></p>
      <% end %>
      <%= render Play::Scenes::LogComponent.new(scene: scene) %>
    </main>

    <%= render Play::Roster::SidebarComponent.new(scene: scene) %>
  </div>

  <div class="sticky bottom-0 z-20 bg-slate-900/95 backdrop-blur">
    <%= render Play::StateIndicatorComponent.new(scene: scene) %>
    <%= render Play::ComposerComponent.new(scene: scene) %>
  </div>
</div>

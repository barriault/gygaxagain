<section data-llm-call-id="<%= llm_call.id %>" class="rounded-lg border border-slate-800 bg-slate-900 p-4 mb-6">
  <% if llm_call.successful? %>
    <div class="rounded bg-emerald-900/40 border border-emerald-700 px-3 py-2 mb-3 text-sm text-emerald-100">
      Success
    </div>
  <% else %>
    <div class="rounded bg-red-900/40 border border-red-700 px-3 py-2 mb-3 text-sm text-red-100">
      Error: <%= llm_call.error_message %>
    </div>
  <% end %>

  <% if llm_call.successful? && llm_call.text.present? %>
    <pre class="whitespace-pre-wrap rounded bg-slate-950 p-3 text-sm text-slate-100 mb-3"><%= llm_call.text %></pre>
  <% end %>

  <dl class="grid grid-cols-2 gap-x-4 gap-y-1 text-sm text-slate-200 mb-3">
    <dt class="text-slate-400">Model</dt>            <dd><%= llm_call.model %></dd>
    <dt class="text-slate-400">Purpose</dt>          <dd><%= llm_call.purpose %></dd>
    <dt class="text-slate-400">Input tokens</dt>     <dd><%= llm_call.input_tokens %></dd>
    <dt class="text-slate-400">Output tokens</dt>    <dd><%= llm_call.output_tokens %></dd>
    <dt class="text-slate-400">Cache creation</dt>   <dd><%= llm_call.cache_creation_tokens %></dd>
    <dt class="text-slate-400">Cache read</dt>       <dd><%= llm_call.cache_read_tokens %></dd>
    <dt class="text-slate-400">Cost</dt>             <dd><%= cost_dollars_formatted %></dd>
    <dt class="text-slate-400">Latency</dt>          <dd><%= llm_call.latency_ms %> ms</dd>
    <dt class="text-slate-400">Request ID</dt>       <dd><code class="text-xs"><%= llm_call.provider_request_id || "—" %></code></dd>
  </dl>

  <details class="mb-2">
    <summary class="cursor-pointer text-sm text-slate-400">prompt_payload</summary>
    <pre class="mt-2 rounded bg-slate-950 p-3 text-xs overflow-x-auto"><%= pretty(llm_call.prompt_payload) %></pre>
  </details>

  <details>
    <summary class="cursor-pointer text-sm text-slate-400">response_payload</summary>
    <pre class="mt-2 rounded bg-slate-950 p-3 text-xs overflow-x-auto"><%= pretty(llm_call.response_payload) %></pre>
  </details>
</section>

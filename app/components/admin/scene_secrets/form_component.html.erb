<h1><%= heading %></h1>
<%= form_with model: secret, url: form_url, method: form_method do |f| %>
  <% if secret.errors.any? %>
    <ul class="errors">
      <% secret.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
    </ul>
  <% end %>
  <div><%= f.label :label %><%= f.text_field :label %></div>
  <div><%= f.label :content %><%= f.text_area :content, rows: 10 %></div>
  <%= f.submit submit %>
<% end %>
<p><%= link_to "← Cancel", admin_campaign_scene_scene_secrets_path(campaign, scene) %></p>

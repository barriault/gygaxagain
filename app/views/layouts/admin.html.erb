<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Gygaxagain admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <div class="min-h-screen bg-slate-950 text-slate-100">
      <%= render Admin::NavComponent.new(current_path: request.path) %>
      <main class="max-w-5xl mx-auto px-4 py-6">
        <% if flash[:notice].present? %>
          <div class="mb-4 flex items-center justify-between rounded border border-emerald-700/40 bg-emerald-900/30 px-4 py-3 text-sm text-emerald-100" data-controller="flash">
            <span><%= flash[:notice] %></span>
            <button type="button" class="ml-4 text-emerald-300 hover:text-white" aria-label="Dismiss" data-action="click->flash#dismiss">×</button>
          </div>
        <% end %>
        <% if flash[:alert].present? %>
          <div class="mb-4 flex items-center justify-between rounded border border-rose-700/40 bg-rose-900/30 px-4 py-3 text-sm text-rose-100" data-controller="flash">
            <span><%= flash[:alert] %></span>
            <button type="button" class="ml-4 text-rose-300 hover:text-white" aria-label="Dismiss" data-action="click->flash#dismiss">×</button>
          </div>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>

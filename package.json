{
  "name": "app",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "bun run build:css && bun run build:js",
    "build:css": "bun scripts/build_css.mjs",
    "watch:css": "bun scripts/build_css.mjs --watch",
    "build:js": "bun bun.config.js",
    "watch:js": "bun bun.config.js --watch"
  },
  "dependencies": {
    "tailwindcss": "4.1.13"
  },
  "devDependencies": {
    "@parcel/watcher": "^2.5.6",
    "@tailwindcss/postcss": "4.1.13",
    "postcss": "^8.5.14"
  }
}
